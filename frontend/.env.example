# Backend API URL (local dev: browser calls this directly)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side API URL inside Docker Compose (middleware + RSC)
# API_INTERNAL_URL=http://api:8000

# Production (Vercel): set NEXT_PUBLIC_API_URL to your Railway URL, e.g.
# NEXT_PUBLIC_API_URL=https://your-api.up.railway.app
# Browser requests use same-origin /api/* (rewritten to Railway); cookies stay on Vercel.
